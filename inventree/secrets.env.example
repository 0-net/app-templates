# InvenTree Secrets — example / documentation only
#
# All values are generated by:
#   make init-app APP=inventree DEPLOYMENT=...
#
# NEVER commit secrets.env to version control.

# Authentik OAuth2 credentials for InvenTree SSO (django-allauth OIDC).
# Generated: openssl rand -hex 16 / openssl rand -base64 32
# Written to TWO places by init-app:
#   1. here (inventree/secrets.env)         → inventree-server/worker env_file
#   2. core/authentik/secrets.env (appended) → Authentik container env_file
INVENTREE_AUTHENTIK_CLIENT_ID=
INVENTREE_AUTHENTIK_CLIENT_SECRET=

# PostgreSQL password for the dedicated InvenTree database.
# Set manually after init-app. Must match what inventree-db is started with.
INVENTREE_DB_PASSWORD=
