# InvenTree proxy Caddyfile
# Serves static/media files directly from the data volume,
# proxies all other requests to the gunicorn server.

:1337 {
	encode gzip

	# Static files (CSS, JS, images — generated by collectstatic)
	handle_path /static/* {
		root * /home/inventree/data/static
		file_server
	}

	# Media files (user uploads)
	handle_path /media/* {
		root * /home/inventree/data/media
		file_server
	}

	# Everything else → gunicorn
	# header_up ensures Django sees https (inner Caddy would otherwise set http)
	reverse_proxy http://inventree-server:8000 {
		header_up X-Forwarded-Proto https
	}
}
