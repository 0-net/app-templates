# Plane secrets — generated by: make init-app APP=plane DEPLOYMENT=...
# PLANE_AUTHENTIK_CLIENT_ID and PLANE_AUTHENTIK_CLIENT_SECRET are written
# automatically by init-app (APP_SSO=true). The vars below are also
# auto-generated (empty value = openssl rand -hex 16).

PLANE_SECRET_KEY=
PLANE_LIVE_SECRET_KEY=
PLANE_DB_PASSWORD=
PLANE_RABBITMQ_PASSWORD=
PLANE_MINIO_ACCESS_KEY=
PLANE_MINIO_SECRET_KEY=
