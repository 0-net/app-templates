# Stirling-PDF secrets — generated by: make init-app APP=stirlingpdf DEPLOYMENT=...

# SSO credentials — generated by init-app, appended to core/authentik/secrets.env
STIRLINGPDF_AUTHENTIK_CLIENT_ID=
STIRLINGPDF_AUTHENTIK_CLIENT_SECRET=

# Initial admin password — generated by init-app (only used on first run)
STIRLINGPDF_ADMIN_PASSWORD=

# SMTP — fill manually in your deployment's secrets.env to enable email
# STIRLINGPDF_MAIL_ENABLED=true
# STIRLINGPDF_SMTP_HOST=smtp.example.com
# STIRLINGPDF_SMTP_PORT=587
# STIRLINGPDF_SMTP_USERNAME=smtp-relay@example.com
# STIRLINGPDF_SMTP_PASSWORD=
# STIRLINGPDF_SMTP_FROM=no-reply@example.com
# STIRLINGPDF_SMTP_TLS=true
