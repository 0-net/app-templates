# Snipe-IT secrets — generated by: make init-app APP=snipeit DEPLOYMENT=...
# All values below are auto-generated (empty value = openssl rand -hex 32).

SNIPEIT_DB_PASSWORD=

# Laravel encryption key — auto-generated in base64 format by init-app.
# To regenerate manually: docker compose run --rm snipeit php artisan key:generate --show
SNIPEIT_APP_KEY=  # @laravel_key

# SMTP password — fill manually in your deployment's secrets.env if SNIPEIT_MAIL_HOST is set
# SNIPEIT_MAIL_PASSWORD=
