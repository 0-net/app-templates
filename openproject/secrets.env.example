# OpenProject Secrets
# Copy this file to secrets.env and fill in your actual values
# NEVER commit secrets.env to version control!

# PostgreSQL Database Password
# Generate with: openssl rand -base64 36 | tr -d '\n'
POSTGRES_PASSWORD=

# Collaborative Editing Secret
# Generate with: openssl rand -base64 32 | tr -d '\n'
COLLABORATIVE_SERVER_SECRET=

# Fixed configuration values
OPENPROJECT_HOST__NAME=projects.0x03.de
OPENPROJECT_HTTPS=false

# Optional: SMTP Configuration (for email notifications)
# Uncomment and configure if you want email support
# EMAIL_DELIVERY_METHOD=smtp
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_DOMAIN=0x03.de
# SMTP_USER_NAME=noreply@0x03.de
# SMTP_PASSWORD=
# SMTP_ENABLE_STARTTLS_AUTO=true
# SMTP_AUTHENTICATION=login
