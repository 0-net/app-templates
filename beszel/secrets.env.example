# Beszel Secrets — example / documentation only
#
# All values are generated by:
#   make init-app APP=beszel DEPLOYMENT=...
#
# NEVER commit secrets.env to version control.

# Authentik OAuth2 credentials for Beszel SSO (PocketBase OIDC).
# Generated: openssl rand -hex 16 / openssl rand -base64 32
# Written to TWO places by init-app:
#   1. here (beszel/secrets.env)            → beszel container env_file
#   2. core/authentik/secrets.env (appended) → Authentik container env_file
BESZEL_AUTHENTIK_CLIENT_ID=
BESZEL_AUTHENTIK_CLIENT_SECRET=
