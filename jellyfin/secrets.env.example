# Jellyfin Secrets — example / documentation only
#
# The actual secrets.env is generated by:
#   make init-app APP=jellyfin DEPLOYMENT=...
#
# Do not fill in values here. This file documents what init-app generates.
# NEVER commit secrets.env to version control.

# Authentik OAuth2 credentials for the Jellyfin SSO plugin.
# Generated: openssl rand -hex 16 / openssl rand -base64 32
# Written to TWO places by init-app:
#   1. here (jellyfin/secrets.env)          → Jellyfin container env_file
#   2. core/authentik/secrets.env (appended) → Authentik container env_file
JELLYFIN_AUTHENTIK_CLIENT_ID=
JELLYFIN_AUTHENTIK_CLIENT_SECRET=
